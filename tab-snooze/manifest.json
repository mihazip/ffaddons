{
  "manifest_version": 2,
  "name": "Tab Snooze",
  "version": "1.4.0",
  "description": "Snooze tabs and reopen them later at your chosen time",

  "browser_specific_settings": {
    "gecko": {
      "id": "tab-snooze@ffaddons.local"
    }
  },

  "data_collection_permissions": {
    "purpose": "This extension collects tab information (URL, title, favicon) only to save and restore snoozed tabs at scheduled times. All data is stored locally in your browser and is never transmitted to external servers.",
    "data_types": ["tabs", "storage"],
    "storage_location": "local"
  },

  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "notifications"
  ],

  "browser_action": {
    "default_icon": {
      "16": "icons/moon-16.png",
      "32": "icons/moon-32.png",
      "48": "icons/moon-48.png"
    },
    "default_title": "Tab Snooze",
    "default_popup": "popup.html"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/moon-16.png",
    "32": "icons/moon-32.png",
    "48": "icons/moon-48.png",
    "128": "icons/moon-128.png"
  }
}
